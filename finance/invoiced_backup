if (!function_exists('fetchapi')) {
    function fetchapi($url) {
        try {
            $newSession = curl_init();
            curl_setopt($newSession, CURLOPT_URL, $url);
            curl_setopt($newSession, CURLOPT_RETURNTRANSFER, true);
            $response = curl_exec($newSession);
            if (curl_errno($newSession)) {
                throw new Exception;
               
            }
            curl_close($newSession);
            return json_decode($response, true);
        } catch (Exception $e) {
            echo 'Error: ' . $e->getMessage();
            return null;
        }
    }
}



